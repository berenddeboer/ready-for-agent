{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**",
      "!!.agents/skills",
      "!!**/dist",
      "!!**/out-tsc",
      "!!**/.nx",
      "!!**/generated",
      "!!**/routeTree.gen.ts",
      "!!**/drizzle"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "complexity": {
        "useArrowFunction": "error",
        "useLiteralKeys": "off"
      },
      "suspicious": {
        "noExplicitAny": "error",
        "noAsyncPromiseExecutor": "error"
      },
      "style": {
        "useImportType": "warn",
        "useConst": "warn",
        "useNodejsImportProtocol": "warn",
        "noNonNullAssertion": "error"
      },
      "correctness": {
        "useExhaustiveDependencies": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "asNeeded",
      "trailingCommas": "all",
      "quoteProperties": "asNeeded",
      "bracketSpacing": true,
      "arrowParentheses": "always"
    }
  },
  "json": {
    "formatter": {
      "indentWidth": 2,
      "trailingCommas": "none"
    },
    "parser": {
      "allowComments": true
    }
  },
  "css": {
    "parser": {
      "cssModules": true,
      "tailwindDirectives": true
    },
    "linter": {
      "enabled": false
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              ":NODE:",
              [":PACKAGE:", "!@ready-for-agent/**"],
              ["@ready-for-agent/**"],
              ":PATH:"
            ],
            "identifierOrder": "lexicographic"
          }
        }
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "**/test/**",
        "**/*.spec.ts",
        "**/*.spec.tsx",
        "**/*.test.ts",
        "**/*.test.tsx"
      ],
      "linter": {
        "rules": {
          "style": {
            "noNonNullAssertion": "off"
          }
        }
      }
    }
  ]
}

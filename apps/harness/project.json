{
  "name": "harness",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "targets": {
    "build": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "continuous": true,
      "executor": "nx:run-commands",
      "options": {
        "command": "ROOT=\"$(cd ../.. && pwd)\" && mkdir -p \"$ROOT/tmp\" && export SQLITE_DATABASE_PATH=\"${SQLITE_DATABASE_PATH:-$ROOT/tmp/ready-for-agent.db}\" && bun --conditions @ready-for-agent/source ../../scripts/run-with-keymaxxer-sidecar.ts bash -c 'bun --conditions @ready-for-agent/source src/server/preflight.ts && vite'",
        "cwd": "apps/harness"
      },
      "dependsOn": [
        "db:migrate",
        {
          "projects": ["graphql-client", "github-service"],
          "target": "generate"
        }
      ]
    },
    "serve": {
      "dependsOn": [
        {
          "projects": ["graphql-client", "github-service"],
          "target": "generate"
        }
      ]
    },
    "start": {
      "continuous": true,
      "executor": "nx:run-commands",
      "options": {
        "command": "ROOT=\"$(cd ../.. && pwd)\" && mkdir -p \"$ROOT/tmp\" && export SQLITE_DATABASE_PATH=\"${SQLITE_DATABASE_PATH:-$ROOT/tmp/ready-for-agent.db}\" && bun --conditions @ready-for-agent/source server.ts",
        "cwd": "apps/harness"
      },
      "dependsOn": ["build"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "bun test"
      },
      "inputs": ["default", "^production"],
      "cache": true,
      "dependsOn": ["^build"]
    },
    "e2e": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "bddgen && playwright test"
      },
      "dependsOn": [
        "build",
        {
          "projects": ["graphql-client"],
          "target": "generate"
        }
      ]
    }
  }
}

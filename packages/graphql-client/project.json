{
  "name": "graphql-client",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/graphql-client/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "generate": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "bun run generate"
      },
      "cache": true,
      "inputs": [
        "{workspaceRoot}/packages/graphql-schema/schema.graphql",
        "{projectRoot}/package.json",
        "{workspaceRoot}/bun.lock"
      ],
      "outputs": ["{projectRoot}/src/generated"]
    },
    "build": {
      "dependsOn": ["generate", "^build"],
      "inputs": [
        "default",
        "^production",
        "{workspaceRoot}/packages/graphql-schema/schema.graphql",
        "{workspaceRoot}/bun.lock"
      ]
    },
    "typecheck": {
      "dependsOn": ["generate", "^build"],
      "inputs": [
        "default",
        "^production",
        "{workspaceRoot}/packages/graphql-schema/schema.graphql",
        "{workspaceRoot}/bun.lock"
      ]
    }
  }
}

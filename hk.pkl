amends "package://github.com/jdx/hk/releases/download/v1.50.0/hk@1.50.0#/Config.pkl"

hooks {
  ["pre-commit"] {
    stash = "git"
    steps {
      ["descriptive-branch"] {
        check = #"""
branch_name=$(git branch --show-current)

case "$branch_name" in
  worktree*[!0-9]* | worktree | "") ;;
  worktree*)
    echo "Refusing to commit on temporary worktree branch '$branch_name'."
    echo "Create or switch to a descriptive branch name first."
    exit 1
    ;;
esac
"""#
      }
      ["bun-lockfile"] {
        depends = "descriptive-branch"
        check = "bun install --frozen-lockfile --lockfile-only --silent --minimum-release-age 0"
      }
      ["biome-json"] {
        depends = "bun-lockfile"
        glob = List("*.json", "**/*.json")
        exclude = "**/generated/**"
        fix = "bun run biome check --write {{files}}"
      }
      ["nx-lint-fix"] {
        depends = "bun-lockfile"
        glob = List("*.ts", "*.tsx", "*.js", "*.jsx", "*.json", "**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx", "**/*.json")
        exclude = "**/generated/**"
        // Strip git local-env-vars and NX_* so hooks under `nx run harness:dev`
        // are not treated as nested Nx invocations (false recursive-task errors).
        fix = #"""
unset $(git rev-parse --local-env-vars)
for v in $(printenv | cut -d= -f1 | grep '^NX_'); do unset "$v"; done
bunx nx affected -t lint --fix --batch --excludeTaskDependencies
"""#
      }
      ["nx-affected"] {
        depends = List("biome-json", "nx-lint-fix")
        check = #"""
unset $(git rev-parse --local-env-vars)
for v in $(printenv | cut -d= -f1 | grep '^NX_'); do unset "$v"; done
bunx nx affected -t lint,typecheck,test --batch
"""#
      }
    }
  }
  ["commit-msg"] {
    steps {
      ["commitlint"] {
        check = "bun run commitlint -- --edit \"{{commit_msg_file}}\""
      }
    }
  }
  ["pre-push"] {
    steps {
      ["no-slot-branch-push"] {
        // Slot branches (worktreeN) are local-only mirrors of main. Pushing them
        // creates origin/worktreeN and Magit Unmerged/Rebase noise.
        // hk does not forward pre-push stdin ref lines to steps, so gate on the
        // current branch name (same pattern as pre-commit descriptive-branch).
        check = #"""
branch_name=$(git branch --show-current)

case "$branch_name" in
  worktree*[!0-9]* | worktree | "") ;;
  worktree*)
    echo "Refusing to push from slot branch '$branch_name'."
    echo "Push a descriptive feature branch instead; leave worktreeN local-only."
    exit 1
    ;;
esac
"""#
      }
    }
  }
}

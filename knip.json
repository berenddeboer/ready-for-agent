{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreDependencies": [
    "@swc/helpers",
    "effect-solutions",
    "keymaxxer",
    "nx",
    "tslib"
  ],
  "ignoreBinaries": ["skills"],
  "ignoreFiles": [".opencode/plugin/**"],
  "workspaces": {
    "apps/harness": {
      "entry": [
        "src/router.tsx",
        "src/server.ts",
        "src/styles.css",
        "test/**/*.test.ts",
        "playwright.config.ts",
        "e2e/steps/**/*.ts",
        "e2e/support/**/*.ts"
      ],
      "project": [
        "src/**/*.{ts,tsx}",
        "test/**/*.ts",
        "e2e/**/*.{ts,tsx}",
        "playwright.config.ts"
      ]
    },
    "apps/keymaxxer-sidecar": {
      "entry": ["test/**/*.test.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "apps/ready-for-agent": {
      "entry": ["src/**/*.test.ts", "src/main.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/github-service": {
      "entry": [
        "src/bin/get-open-pr-number.ts",
        "src/bin/get-pr-check-status.ts",
        "src/bin/get-pr-lifecycle-status.ts",
        "src/bin/list-ready-issues.ts",
        "src/bin/mark-pr-ready-for-review.ts",
        "src/bin/merge-pull-request.ts",
        "test/**/*.{test,spec}.ts"
      ],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "packages/db-schema": {
      "entry": [],
      "project": ["src/**/*.ts"]
    },
    "packages/graphql-schema": {
      "entry": [],
      "project": ["src/**/*.ts"]
    },
    "packages/db": {
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/*": {
      "entry": ["test/**/*.{test,spec}.ts"],
      "project": ["src/**/*.{ts,tsx}", "test/**/*.ts"]
    }
  }
}

{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreDependencies": ["@swc/helpers", "nx", "tslib"],
  "ignoreBinaries": ["skills"],
  "workspaces": {
    "apps/harness": {
      "entry": [
        "server.ts",
        "src/router.tsx",
        "src/server.ts",
        "test/**/*.test.ts"
      ],
      "project": ["src/**/*.{ts,tsx}", "test/**/*.ts"]
    },
    "apps/keymaxxer-sidecar": {
      "entry": ["src/main.ts", "test/**/*.test.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "apps/cli": {
      "entry": ["src/main.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/graphql-client": {
      "entry": ["src/index.ts"],
      "project": [
        "src/index.ts",
        "src/generated/index.ts",
        "src/generated/schema.ts",
        "src/generated/types.ts"
      ]
    },
    "packages/github-service": {
      "entry": ["test/**/*.{test,spec}.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"],
      "ignoreIssues": {
        "src/internal/generated/**": ["exports", "types"]
      }
    },
    "packages/db": {
      "entry": ["src/bin/migrate.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/*": {
      "entry": ["src/index.ts", "test/**/*.{test,spec}.ts"],
      "project": ["src/**/*.{ts,tsx}", "test/**/*.ts"]
    }
  }
}

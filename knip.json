{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreDependencies": ["@swc/helpers", "effect-solutions", "nx", "tslib"],
  "ignoreBinaries": ["skills"],
  "ignoreFiles": [".opencode/plugin/**"],
  "workspaces": {
    "apps/harness": {
      "entry": [
        "server.ts",
        "src/router.tsx",
        "src/server.ts",
        "src/styles.css",
        "test/**/*.test.ts"
      ],
      "project": ["src/**/*.{ts,tsx}", "test/**/*.ts"]
    },
    "apps/keymaxxer-sidecar": {
      "entry": ["src/main.ts", "test/**/*.test.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "apps/cli": {
      "entry": ["src/main.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/graphql-client": {
      "entry": ["src/index.ts"]
    },
    "packages/github-service": {
      "entry": ["src/bin/list-ready-issues.ts", "test/**/*.{test,spec}.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "packages/db": {
      "entry": ["src/bin/migrate.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/*": {
      "entry": ["src/index.ts", "test/**/*.{test,spec}.ts"],
      "project": ["src/**/*.{ts,tsx}", "test/**/*.ts"]
    }
  }
}
